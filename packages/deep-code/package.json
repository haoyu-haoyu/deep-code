{
  "name": "@deepcode-ai/deep-code",
  "version": "0.3.0",
  "description": "DeepSeek-native Deep Code terminal coding assistant for agentic software development.",
  "keywords": [
    "deepseek",
    "cli",
    "coding-assistant",
    "agent",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haoyu-haoyu/deep-code.git"
  },
  "bin": {
    "deepcode": "deepcode.js",
    "deep-code": "deepcode.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "author": "Deep Code",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/haoyu-haoyu/deep-code#readme",
  "bugs": {
    "url": "https://github.com/haoyu-haoyu/deep-code/issues"
  },
  "files": [
    "deepcode.js",
    "dist/",
    "src/",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build:full-cli": "bun scripts/build-full-cli.mjs",
    "build:full-cli-inline": "bun scripts/build-full-cli.mjs --inline-requires",
    "build:binaries": "node scripts/build-binaries.mjs",
    "test:deepcode": "node --test test/deepcode-native.test.mjs test/deepcode-package.test.mjs",
    "test:tui-deepseek": "bun test test/tui-deepseek.test.mjs",
    "test:real-cache-e2e": "node scripts/deepseek-cache-e2e.mjs",
    "test:reasoning-cost": "node scripts/deepseek-reasoning-cost-probe.mjs",
    "test:toolchain-e2e": "node scripts/deepseek-toolchain-e2e.mjs",
    "test:acp-e2e": "node scripts/deepseek-acp-e2e.mjs",
    "perf:fixture": "node scripts/perf/generate-fixture.mjs --count=1000",
    "perf:baseline": "bun scripts/perf-baseline.mjs",
    "perf:compare": "node scripts/perf-compare.mjs",
    "prepublishOnly": "node -e \"if (!process.env.AUTHORIZED) { console.error('ERROR: Direct publishing is not allowed.\\nPlease see the release workflow documentation to publish this package.'); process.exit(1); }\""
  },
  "dependencies": {},
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "^0.34.2",
    "@img/sharp-darwin-x64": "^0.34.2",
    "@img/sharp-linux-arm": "^0.34.2",
    "@img/sharp-linux-arm64": "^0.34.2",
    "@img/sharp-linux-x64": "^0.34.2",
    "@img/sharp-linuxmusl-arm64": "^0.34.2",
    "@img/sharp-linuxmusl-x64": "^0.34.2",
    "@img/sharp-win32-arm64": "^0.34.2",
    "@img/sharp-win32-x64": "^0.34.2"
  }
}
